# ── Ollama (runs on host, shared by all agents) ──────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
MODEL_DEFAULT=qwen2.5:3b-instruct
MODEL_CONVERSATIONAL=qwen2.5:7b-instruct
MODEL_EMBED=nomic-embed-text
MODEL_REASONING=deepseek-r1:7b
MODEL_OCR=llava:7b

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wealthmesh
POSTGRES_USER=wealthmesh
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=wealth
KEYCLOAK_CLIENT_ID=backend
KEYCLOAK_CLIENT_SECRET=changeme

# ── Langfuse ──────────────────────────────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=changeme
LANGFUSE_SECRET_KEY=changeme

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Services (internal ports) ─────────────────────────────────────────────────
ORCHESTRATOR_PORT=8000
AGENT_FINANCIAL_PORT=8001
AGENT_MARKET_PORT=8002
AGENT_DOCS_PORT=8003
AGENT_ACTION_PORT=8004
AGENT_QA_PORT=8005
VOICE_PORT=8006

# ── Mail sandbox (MailHog) ────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_STARTTLS=false
SMTP_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@wealthmesh.local
FROM_NAME=LaRuche Advisor

# Gmail example, put real values in .env.local only:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_STARTTLS=true
# SMTP_USERNAME=your-gmail@gmail.com
# SMTP_PASSWORD=your-google-app-password
# FROM_EMAIL=your-gmail@gmail.com
# FROM_NAME=LaRuche Advisor
